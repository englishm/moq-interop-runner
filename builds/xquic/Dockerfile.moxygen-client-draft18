# The published moxygen interop client contains the draft-18 protocol stack,
# but its test-only ALPN preference list still starts at moqt-16. Keep the
# upstream binary intact apart from selecting its built-in draft-18 path.
FROM ghcr.io/facebookexperimental/moxygen-interop-client@sha256:14abc9e7041005b010979c696202cec8d0f3b6c313c5fd2d108189650d995409

RUN perl -0777 -pi -e '\
    BEGIN { \
        $$old = "moqt-16\0moqt-14\0"; \
        $$new = "moqt-18\0moqt-14\0"; \
    } \
    $$count += s/\Q$$old\E/$$new/g; \
    END { die "unexpected moxygen ALPN table\n" unless $$count == 1; }' \
    /usr/local/bin/moq_interop_client

LABEL org.opencontainers.image.description="moxygen interop client with its built-in draft-18 ALPN enabled for xquic local testing"
