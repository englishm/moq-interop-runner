# Native draft-18 aiomoqt relay used only by the xquic local Docker gate.
# This mirrors Dockerfile.aiomoqt-client-draft18 so ARM hosts do not depend on
# emulating the published amd64 image. It does not replace aiomoqt's registry
# entry or adapter configuration.
FROM python:3.12-slim

ARG AIOMOQT_REPOSITORY=https://github.com/gmarzot/aiomoqt.git
ARG AIOMOQT_REF=fdb41348376f1286a09d11352e15a288c620485a

RUN apt-get update \
    && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        ca-certificates git \
    && rm -rf /var/lib/apt/lists/*

RUN git init /src/aiomoqt \
    && git -C /src/aiomoqt remote add origin "${AIOMOQT_REPOSITORY}" \
    && git -C /src/aiomoqt fetch --depth 1 origin "${AIOMOQT_REF}" \
    && git -C /src/aiomoqt checkout --detach FETCH_HEAD \
    && test "$(git -C /src/aiomoqt rev-parse HEAD)" = "${AIOMOQT_REF}" \
    && pip install --no-cache-dir /src/aiomoqt \
    && rm -rf /src/aiomoqt

ENV DRAFT=18
ENV MOQT_DRAFT=18

EXPOSE 4443/udp

HEALTHCHECK --interval=2s --timeout=5s --start-period=5s --retries=20 \
    CMD grep -qi ":115B" /proc/net/udp6 || grep -qi ":115B" /proc/net/udp || exit 1

ENTRYPOINT ["python", "-m", "aiomoqt.examples.moq_interop_relay", \
            "--bind", "0.0.0.0", "--port", "4443", \
            "--cert", "/certs/cert.pem", "--key", "/certs/priv.key", \
            "--quic"]
