# Adapter: wraps the MOQ5 (libmoq) interop client with an env-var entrypoint
# for compatibility with moq-interop-runner's test-external target.
FROM moq5-client:latest AS base
COPY entrypoint-client.sh /usr/local/bin/entrypoint.sh
RUN chmod +x /usr/local/bin/entrypoint.sh
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
